-- Boolean type
CREATE TABLE booltest (a boolean, b boolean);
CREATE TABLE
INSERT INTO booltest VALUES (true, false);
INSERT 0 1
INSERT INTO booltest VALUES (false, true);
INSERT 0 1
INSERT INTO booltest VALUES (true, true);
INSERT 0 1
SELECT * FROM booltest;
 a | b
---+---
 t | f
 f | t
 t | t

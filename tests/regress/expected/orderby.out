-- ORDER BY variations
CREATE TABLE t2 (x int, y int);
CREATE TABLE
INSERT INTO t2 VALUES (3, 10);
INSERT 0 1
INSERT INTO t2 VALUES (1, 30);
INSERT 0 1
INSERT INTO t2 VALUES (2, 20);
INSERT 0 1
INSERT INTO t2 VALUES (1, 10);
INSERT 0 1
-- Basic ORDER BY
SELECT * FROM t2 ORDER BY x;
 x | y 
---+----
 1 | 30
 1 | 10
 2 | 20
 3 | 10
(4 rows)
SELECT * FROM t2 ORDER BY y DESC;
 x | y 
---+----
 1 | 30
 2 | 20
 3 | 10
 1 | 10
(4 rows)
-- Multi-column ORDER BY
SELECT * FROM t2 ORDER BY x ASC, y DESC;
 x | y 
---+----
 1 | 30
 1 | 10
 2 | 20
 3 | 10
(4 rows)

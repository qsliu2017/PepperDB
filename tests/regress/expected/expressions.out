-- Type casting, operator precedence, parentheses
-- CAST
SELECT CAST(42 AS bigint);
 ?column?
---------
       42
(1 row)
SELECT CAST(3.14 AS int);
 ?column?
---------
        3
(1 row)
SELECT CAST(1 AS text);
 ?column?
---------
 1       
(1 row)
-- PostgreSQL :: cast syntax
SELECT 42::bigint;
 ?column?
---------
       42
(1 row)
SELECT 100::smallint;
 ?column?
---------
      100
(1 row)
-- Operator precedence: * before +
SELECT 2 + 3 * 4;
 ?column?
---------
       14
(1 row)
SELECT (2 + 3) * 4;
 ?column?
---------
       20
(1 row)
-- Nested parentheses
SELECT ((1 + 2) * (3 + 4));
 ?column?
---------
       21
(1 row)
-- Mixed arithmetic
SELECT 10 / 3;
 ?column?
---------
        3
(1 row)
SELECT 10 % 3;
 ?column?
---------
        1
(1 row)
SELECT -5 + 3;
 ?column?
---------
       -2
(1 row)
SELECT -(5 + 3);
 ?column?
---------
       -8
(1 row)
